pipeline { 
    agent { 
        docker { 
            image 'markhobson/maven-chrome' 
            args '-u root:root -v /var/lib/jenkins/.m2:/root/.m2' 
        } 
    } 

    stages { 
        stage('Clone Repository') { 
            steps { 
                // Note: Replace with your actual repository URL
                git branch: 'main', url: 'https://github.com/YOUR_GITHUB_USERNAME/selenium-test-project.git' 
            } 
        } 

        stage('Test') { 
            steps { 
                // Navigate to the project directory if it's in a subdirectory
                sh 'mvn -f selenium-test-project/pom.xml test' 
            } 
        } 
        
        stage('Publish Test Results') { 
            steps { 
                junit '**/target/surefire-reports/*.xml' 
            } 
        } 
    } 

    post { 
        always { 
            script { 
                // Get commit author email 
                sh "git config --global --add safe.directory ${env.WORKSPACE}" 
                def committer = sh( 
                    script: "git log -1 --pretty=format:'%ae'", 
                    returnStdout: true 
                ).trim() 

                // Check if reports exist before grepping
                def exists = sh(script: "ls selenium-test-project/target/surefire-reports/*.xml", returnStatus: true) == 0
                
                if (exists) {
                    def raw = sh( 
                        script: "grep -h \"<testcase\" selenium-test-project/target/surefire-reports/*.xml", 
                        returnStdout: true 
                    ).trim() 

                    int total = 0 
                    int passed = 0 
                    int failed = 0 
                    int skipped = 0 

                    def details = "" 

                    raw.split('\n').each { line -> 
                        total++ 

                        def nameMatch = (line =~ /name=\"([^\"]+)\"/)
                        if (nameMatch.size() > 0) {
                            def name = nameMatch[0][1] 

                            if (line.contains("<failure")) { 
                                failed++ 
                                details += "${name} — FAILED\n" 
                            } else if (line.contains("<skipped") || line.contains("</skipped>")) { 
                                skipped++ 
                                details += "${name} — SKIPPED\n" 
                            } else { 
                                passed++ 
                                details += "${name} — PASSED\n" 
                            } 
                        }
                    } 

                    def emailBody = """ 
Test Summary (Build #${env.BUILD_NUMBER}) 

Total Tests:   ${total} 
Passed:        ${passed} 
Failed:        ${failed} 
Skipped:       ${skipped} 

Detailed Results: 
${details} 

""" 

                    emailext( 
                        to: committer, 
                        subject: "Build #${env.BUILD_NUMBER} Test Results", 
                        body: emailBody 
                    ) 
                } else {
                    println "No test reports found. Skipping email with details."
                }
            } 
        } 
    } 
}
